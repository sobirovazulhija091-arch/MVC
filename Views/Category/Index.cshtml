<div class="category-container">
    <h2 class="title">Category List</h2>

    <div class="table-wrapper">
        <table class="product-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td class="name">@p.Name</td>
                    <td>@p.Description</td>
                    <td class="actions">
                        <a asp-action="GetById" asp-route-id="@p.Id" class="btn btn-view">View</a>
                        <a asp-action="Update" asp-route-id="@p.Id" class="btn btn-edit">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-delete">Delete</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="bottom-links">
        <a asp-action="Create" class="btn btn-create">+ Create New Category</a>
    </div>
</div>