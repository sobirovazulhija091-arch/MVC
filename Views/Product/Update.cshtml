@model Product

<h2 class="title">Update Product</h2>

<div class="form-container">
    <form asp-action="Update" method="post">
         <div class="form-group">
            <label>Id</label>
            <input asp-for="Id" class="form-input"/>
        </div>

        <div class="form-group">
            <label>Name</label>
            <input asp-for="Name" class="form-input"/>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input asp-for="Price" class="form-input"/>
        </div>

        <div class="buttons">
            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-action="Index" class="btn btn-secondary">Exit</a>
            <a asp-action="GetById" asp-route-id="@Model.Id" class="btn btn-info">Get By Id</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
        </div>

    </form>
</div>